{
  "info": {
    "_postman_id": "f0371c78-618d-4ed6-bc6b-47f75e1c9e70",
    "name": "Parcel documents API",
    "description": "For international shipments, customs documentation is generated alongside the shipping label. These documents can be downloaded separately from the shipping label in various formats and resolutions via this API.\n\n\nContact Support:\n Name: Sendcloud API Support\n Email: contact@sendcloud.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:16:32.000Z",
    "updatedAt": "2026-06-05T15:16:32.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-f0371c78-618d-4ed6-bc6b-47f75e1c9e70"
  },
