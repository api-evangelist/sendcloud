                "type": "query",
                "description": "first delivery start date"
              },
              {
                "name": "end_date",
                "value": "",
                "type": "query",
                "description": "first delivery end date"
              }
            ],
            "auth": {
              "type": "basic",
              "username": "{{username}}",
              "password": "{{password}}"
            }
          },
          "docs": "Retrieves the average transit time of a parcel per shipping method and carrier.\nYou can filter the results by origin and destination country, as well as start and end dates."
        }
