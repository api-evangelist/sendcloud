              {
                "name": "direction",
                "value": "",
                "type": "query",
                "description": "incoming or outgoing parcels"
              },
              {
                "name": "brand_id",
                "value": "",
                "type": "query",
                "description": "filtering by brand id"
              },
              {
                "name": "product_name",
                "value": "",
                "type": "query",
                "description": "filtering by product name"
              },
              {
                "name": "product_sku",
                "value": "",
                "type": "query",
                "description": "filtering by product sku"
              }
            ]
          },
          "docs": "Returns number of parcels for the last number of days selected."
        }
