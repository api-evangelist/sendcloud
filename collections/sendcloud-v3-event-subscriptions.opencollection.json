            "auth": {
              "type": "basic",
              "username": "{{username}}",
              "password": "{{password}}"
            }
          },
          "docs": "Retrieve a specific connection by its id."
        },
        {
          "info": {
            "name": "Update a connection",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://panel.sendcloud.sc/api/v3/event-subscriptions/connections/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "The id of the connection."
              }
